# Copy to .env and adjust.

# PostgreSQL (see docker-compose.yml for local dev)
DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/newsapp

# CORS — include your Vite origin
CLIENT_ORIGIN=http://localhost:5173

# Google OAuth (Web client ID from Google Cloud Console — same as frontend VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# JWT (use a long random string in production)
JWT_SECRET=change-me-to-a-long-random-secret

# News providers (set at least one paid key or rely on the Inshorts community proxy)
NEWSAPI_KEY=
GNEWS_KEY=
CURRENTS_API_KEY=
MEDIASTACK_KEY=

# AI: grok | openai | claude | gemini
AI_PROVIDER=openai
AI_FALLBACKS=

GROK_API_KEY=
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-2-latest

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-1.5-flash

# News cache: upstream APIs run at most once per TTL; users read Postgres only.
NEWS_CACHE_TTL_SECONDS=900
NEWS_FETCH_BATCH_SIZE=50
# Optional cron / manual warm-up: POST /api/news/refresh with header X-Refresh-Secret
REFRESH_SECRET=
